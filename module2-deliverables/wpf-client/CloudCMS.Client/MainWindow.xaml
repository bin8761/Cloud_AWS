<Window x:Class="CloudCMS.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CloudCMS Lockscreen"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Background="#0F172A">
        <Border Visibility="{Binding IsLocked, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="#111827">
            <Grid>
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="LOCKED"
                               Foreground="White"
                               FontSize="72"
                               FontWeight="Bold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#9CA3AF"
                               FontSize="24"
                               Margin="0,16,0,0"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding RealtimeStatus}"
                               Foreground="#60A5FA"
                               FontSize="16"
                               Margin="0,10,0,0"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Border HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="20"
                Background="#111827"
                Padding="14"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="Floating Bar"
                           Foreground="#9CA3AF"
                           FontSize="12" />
                <TextBlock Text="{Binding StatusText}"
                           Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="18"
                           Margin="0,4,0,0" />
                <TextBlock Text="{Binding RealtimeStatus}"
                           Foreground="#60A5FA"
                           FontSize="12"
                           Margin="0,4,0,0" />
            </StackPanel>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility"
                            Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLocked}"
                                     Value="True">
                            <Setter Property="Visibility"
                                    Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>
    </Grid>
</Window>
