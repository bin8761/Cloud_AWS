{
    "name": "cloudcms-backend",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc -p tsconfig.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "prisma:generate": "prisma generate",
        "start": "node dist/server.js"
    },
    "dependencies": {
        "@prisma/client": "^6.19.3",
        "cors": "*",
        "dotenv": "*",
        "express": "*",
        "helmet": "*",
        "pino": "*",
        "zod": "*"
    },
    "devDependencies": {
        "@types/cors": "*",
        "@types/express": "*",
        "@types/node": "*",
        "@types/supertest": "*",
        "prisma": "^6.19.3",
        "supertest": "*",
        "tsx": "*",
        "typescript": "*",
        "vitest": "*"
    }
}
