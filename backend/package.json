{
    "name": "cloudcms-backend",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc -p tsconfig.json",
        "test": "vitest run",
        "test:auth:live": "vitest run tests/auth/auth.api.live.test.ts",
        "test:auth:live:security": "vitest run tests/auth/auth.api.live.security.test.ts",
        "test:auth:live:all": "vitest run tests/auth/auth.api.live.test.ts tests/auth/auth.api.live.security.test.ts",
        "test:auth:live:success:manual": "powershell -ExecutionPolicy Bypass -File scripts/auth-live-success.ps1",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "prisma:migrate": "npx prisma migrate dev",
        "prisma:generate": "npx prisma generate",
        "start": "node dist/server.js"
    },
    "dependencies": {
        "@prisma/client": "^6.19.3",
        "bcrypt": "*",
        "cors": "*",
        "dotenv": "*",
        "express": "*",
        "helmet": "*",
        "jose": "*",
        "multer": "^2.1.1",
        "nodemailer": "*",
        "pino": "*",
        "zod": "*"
    },
    "devDependencies": {
        "@types/bcrypt": "*",
        "@types/cors": "*",
        "@types/express": "*",
        "@types/multer": "^2.1.0",
        "@types/node": "*",
        "@types/nodemailer": "*",
        "@types/supertest": "*",
        "prisma": "^6.19.3",
        "supertest": "*",
        "tsx": "*",
        "typescript": "*",
        "vitest": "*"
    }
}
