{
    "$schema":  "https://json.schemastore.org/tsconfig",
    "compilerOptions":  {
                            "rootDir":  "src",
                            "outDir":  "dist",
                            "target":  "ES2022",
                            "module":  "NodeNext",
                            "moduleResolution":  "NodeNext",
                            "lib":  [
                                        "ES2023"
                                    ],
                            "strict":  true,
                            "types":  [
                                          "node",
                                          "vitest/globals"
                                      ]
                        },
    "include":  [
                    "src",
                    "tests"
                ]
}
